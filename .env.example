# GitHub OAuth 应用配置
# 在 https://github.com/settings/developers 创建一个 OAuth App
# Authorization callback URL 需要与下方 GITHUB_OAUTH_REDIRECT_URI 一致
# 例如本地开发：http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 可选：覆盖默认回调 URL；未设置时根据请求 origin + basePath 推断
# GITHUB_OAUTH_REDIRECT_URI=https://your-domain.com/api/auth/github/callback

# 可选：自定义 OAuth scope，默认：repo workflow read:user user:email
# GITHUB_OAUTH_SCOPE=repo workflow read:user user:email

# 可选：子路径部署
# NEXT_PUBLIC_BASE_PATH=
